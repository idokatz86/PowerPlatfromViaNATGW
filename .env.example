# Copy this file to your shell profile or export values manually before running scripts.
# Do not commit a populated .env file.

# Azure and Power Platform
export SUBSCRIPTION_ID="<azure-subscription-id>"
export TENANT_ID="<microsoft-entra-tenant-id>"
export POWER_PLATFORM_ENVIRONMENT_ID="<power-platform-environment-id>"

# Shared naming
export RESOURCE_GROUP="<resource-group-name>"
export LOCATION="<primary-azure-region>"
export POLICY_NAME="<power-platform-enterprise-policy-name>"
export POLICY_LOCATION="<power-platform-policy-location>"

# Bicep network parameters
export PARAMETERS_FILE="infra/main.parameters.json"

# Regional proxy deployment. Run once per region with region-specific values.
export PROXY_RESOURCE_GROUP="$RESOURCE_GROUP"
export PROXY_LOCATION="<proxy-region>"
export PROXY_VNET_NAME="<existing-vnet-name>"
export PROXY_SUBNET_NAME="<container-apps-environment-subnet-name>"
export PROXY_SUBNET_PREFIX="<container-apps-environment-subnet-prefix>"
export PROXY_NAT_NAME="<nat-gateway-name-attached-to-proxy-subnet>"
export PROXY_PUBLIC_IP_NAME="<nat-gateway-public-ip-name>"
export PROXY_LOG_ANALYTICS_NAME="<log-analytics-workspace-name>"
export PROXY_CONTAINER_ENV_NAME="<container-apps-environment-name>"
export PROXY_CONTAINER_APP_NAME="<container-app-name>"
export PROXY_ACR_NAME="<globally-unique-acr-name>"
export PROXY_OUTPUT_PATH=".azure/container-apps-proxy-<region>.json"

# Custom connector generation. Hosts may be plain hostnames or full https URLs.
export NORTH_REGION_PROXY_HOST="<first-regional-proxy-host>"
export WEST_REGION_PROXY_HOST="<second-regional-proxy-host>"
export NORTH_REGION_CONNECTOR_DISPLAY_NAME="North Region NAT Proxy"
export WEST_REGION_CONNECTOR_DISPLAY_NAME="West Region NAT Proxy"

# Logic App example values
export LOGIC_APP_RESOURCE_GROUP="$RESOURCE_GROUP"
export NORTH_EUROPE_PROXY_URL="<primary-or-north-region-proxy-url>"
export WEST_EUROPE_PROXY_URL="<secondary-or-west-region-proxy-url>"
export NORTH_EUROPE_WORKFLOW_NAME="<logic-app-workflow-name-1>"
export WEST_EUROPE_WORKFLOW_NAME="<logic-app-workflow-name-2>"

# Optional inspection endpoint for direct source-IP proof.
export INSPECTION_RESOURCE_GROUP="<inspection-resource-group-name>"
export INSPECTION_LOCATION="<inspection-region>"
export INSPECTION_PLAN_NAME="<app-service-plan-name>"
export INSPECTION_WEBAPP_NAME="<globally-unique-web-app-name>"
export INSPECTION_SKU="B1"